{
  "name": "txma-ticf-query-results-delivery",
  "description": "Deliver results of Athena queries to TICF analysts",
  "repository": {
    "type": "git",
    "url": "https://github.com/govuk-one-login/txma-ticf-query-results-delivery.git"
  },
  "author": "GDS",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit && tsx ./esbuild.config.ts",
    "lint": "prettier . --check || exit 1 ; eslint . --max-warnings=0",
    "lint:fix": "prettier . --write ; eslint . --fix",
    "postinstall": "husky install",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run -c tests/integration-tests/vitest.config.integration.ts",
    "test:e2e": "vitest run -c tests/e2e-tests/vitest.config.e2e.ts"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.33.1",
    "@aws-sdk/client-dynamodb": "3.1058.0",
    "@aws-sdk/client-s3": "3.1058.0",
    "@aws-sdk/client-secrets-manager": "3.1058.0",
    "@aws-sdk/client-sqs": "3.1058.0",
    "@aws-sdk/s3-request-presigner": "3.1058.0",
    "@aws-sdk/util-endpoints": "3.996.14",
    "notifications-node-client": "8.4.0"
  },
  "resolutions": {
    "micromatch": "4.0.8"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.1060.0",
    "@aws-sdk/client-lambda": "3.1060.0",
    "@aws-sdk/client-ssm": "3.1060.0",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "8.10.161",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "aws-sdk-client-mock": "4.1.0",
    "axios": "1.17.0",
    "esbuild": "0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.6.0",
    "husky": "9.1.7",
    "jsonwebtoken": "9.0.3",
    "lint-staged": "17.0.7",
    "node-html-parser": "7.1.0",
    "prettier": "3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.18",
    "yaml-cfn": "0.3.2"
  },
  "lint-staged": {
    "*": "prettier --write",
    "*.{js,ts}": "eslint --fix"
  }
}
